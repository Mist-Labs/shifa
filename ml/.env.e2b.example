# SHIFA E2B mobile-first training profile.
# Copy values into ml/.env on the GPU machine, or export these variables
# before running finetune/finetune_unsloth.py.

SHIFA_BASE_MODEL=google/gemma-4-E2B-it
SHIFA_MODEL_VARIANT=e2b

# E2B should train faster and use less memory than E4B. Keep 4096 unless
# validation shows prompt truncation; then raise to 8192.
SHIFA_MAX_SEQ_LENGTH=4096
SHIFA_LOAD_IN_4BIT=1
SHIFA_NUM_EPOCHS=3
SHIFA_BATCH_SIZE=4
SHIFA_GRAD_ACCUM=2
SHIFA_LEARNING_RATE=2e-4
SHIFA_WARMUP_STEPS=10
SHIFA_LOGGING_STEPS=10
SHIFA_SAVE_STRATEGY=epoch
SHIFA_OPTIM=adamw_8bit
SHIFA_DATALOADER_WORKERS=2
SHIFA_DATASET_NUM_PROC=2
SHIFA_LORA_R=16
SHIFA_LORA_ALPHA=16
SHIFA_SEED=42

# Reuse cleaned E4B data; do not regenerate data for the first E2B run.
SHIFA_TRAIN_FILE=data/processed/training_final.jsonl
SHIFA_TEST_CASES=data/test_cases/imci_test_60.jsonl
SHIFA_TEST_FILE=data/test_cases/imci_test_60.jsonl

# Keep E2B outputs separate from validated E4B artifacts.
SHIFA_MODEL_DIR=models/shifa-gemma4-e2b-finetuned
SHIFA_CHECKPOINT_DIR=models/shifa-gemma4-e2b-checkpoints
SHIFA_VALIDATION_REPORT=reports/e2b_validation_metrics.json
SHIFA_TRAINING_MANIFEST=reports/e2b_training_manifest.json
SHIFA_VALIDATION_REPORT_KEY=reports/e2b_validation_metrics.json
SHIFA_TRAINING_MANIFEST_KEY=reports/e2b_training_manifest.json

# Optional runtime output path after E2B export/quantization.
SHIFA_LITERT_OUTPUT=models/shifa-gemma4-e2b-finetuned/shifa-gemma4-e2b-finetuned.litertlm
SHIFA_LITERT_SOURCE=
