# SHIFA ML pipeline configuration. Copy to ml/.env on the remote GPU machine.
# Never commit real tokens, account IDs, bucket names, or credentials.

# Hugging Face access for gated Gemma model downloads.
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
SHIFA_BASE_MODEL=google/gemma-4-e4b-it
SHIFA_MODEL_VARIANT=e4b

# Training controls.
SHIFA_MAX_SEQ_LENGTH=8192
SHIFA_LOAD_IN_4BIT=1
SHIFA_NUM_EPOCHS=3
SHIFA_BATCH_SIZE=2
SHIFA_GRAD_ACCUM=4
SHIFA_LEARNING_RATE=2e-4
SHIFA_LORA_R=16
SHIFA_LORA_ALPHA=16
SHIFA_SEED=42
SHIFA_CASE_COUNT=2000

# Paths are relative to ml/ unless absolute.
SHIFA_RAW_DATA_DIR=data/raw
SHIFA_PROCESSED_DIR=data/processed
SHIFA_TEST_CASES=data/test_cases/imci_test_60.jsonl
SHIFA_TRAIN_FILE=data/processed/training_final.jsonl
SHIFA_SYNTHETIC_FILE=data/processed/synthetic_cases_2000.jsonl
SHIFA_MODEL_DIR=models/shifa-gemma4-e4b-finetuned
SHIFA_CHECKPOINT_DIR=models/shifa-gemma4-checkpoints
SHIFA_VALIDATION_REPORT=reports/validation_metrics.json
SHIFA_TRAINING_MANIFEST=reports/training_manifest.json
SHIFA_VALIDATION_REPORT_KEY=validation_metrics.json
SHIFA_TRAINING_MANIFEST_KEY=training_manifest.json
SHIFA_LITERT_OUTPUT=models/shifa-gemma4-e4b-finetuned/shifa-gemma4-e4b-finetuned.litertlm
# Optional: local path or HTTPS URL for an already exported .gguf/.litertlm/.task/.tflite runtime artifact.
SHIFA_LITERT_SOURCE=

# Optional experiment tracking.
WANDB_API_KEY=
WANDB_PROJECT=shifa-clinical-gemma
WANDB_MODE=disabled

# Optional Cloudflare R2 upload using S3-compatible credentials.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# SHIFA Guard visual weapon detector.
SHIFA_GUARD_DATASET=Subh775/WeaponDetection
SHIFA_GUARD_DATA_DIR=data/guard/weapon_detection
SHIFA_GUARD_DATA_YAML=data/guard/weapon_detection/data.yaml
SHIFA_GUARD_BASE_MODEL=yolo11n.pt
SHIFA_GUARD_RUNS_DIR=models/guard-runs
SHIFA_GUARD_RUN_NAME=shifa-guard-weapon-detector
SHIFA_GUARD_MODEL_DIR=models/shifa-guard-weapon-detector
SHIFA_GUARD_PT_MODEL=models/shifa-guard-weapon-detector/best.pt
SHIFA_GUARD_TFLITE_MODEL=models/shifa-guard-weapon-detector/shifa-guard-weapon-detector.tflite
SHIFA_GUARD_EPOCHS=80
SHIFA_GUARD_IMAGE_SIZE=640
SHIFA_GUARD_BATCH_SIZE=16
SHIFA_GUARD_PATIENCE=20
SHIFA_GUARD_DEVICE=0
SHIFA_GUARD_VAL_CONF=0.35
SHIFA_GUARD_CONFIRM_CONF=0.65
SHIFA_GUARD_VAL_IOU=0.5
SHIFA_GUARD_EXPORT_FORMAT=tflite
SHIFA_GUARD_INT8=1
SHIFA_GUARD_VALIDATION_REPORT=reports/guard_validation_metrics.json
SHIFA_GUARD_MIN_OVERALL_MAP50=0.80
SHIFA_GUARD_MIN_WEAPON_MAP50=0.85
