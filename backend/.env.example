NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Comma-separated origins. Use your Vercel/dashboard URL in production.
CORS_ORIGINS=https://your-shifa-dashboard.example

# Required in production. Use at least 32 random characters.
JWT_SECRET=replace_with_a_32_plus_character_secure_value

# Multipart upload limit for clinical photos, referral cards, etc.
MAX_UPLOAD_BYTES=10485760

# Coordinator database. Required for multi-instance production.
DATABASE_URL=postgres://user:password@host:5432/shifa

# Backend clinical AI fallback/validation path. Mobile field inference still uses Gemma via LiteRT.
GOOGLE_API_KEY=replace_with_google_api_key
CLINICAL_AI_MODEL=gemini-2.5-flash

# Optional HMAC for private coordinator/admin routes.
# Keep disabled for mobile-first preview deployments; /api/sync is public either way.
SHIFA_REQUIRE_HMAC=false
# SHIFA_HMAC_SECRET=replace_with_a_32_plus_character_shared_secret

# Optional single-instance durable store. Use a mounted volume in production.
# For multi-instance production, replace this with PostgreSQL/PostGIS persistence.
SHIFA_STORE_FILE=/data/shifa-store.json
